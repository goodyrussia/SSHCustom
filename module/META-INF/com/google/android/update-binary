#!/sbin/sh
#################
# Initialization
#################

umask 022

# echo before loading util_functions
ui_print() { echo "$1"; }

require_new_magisk() {
  ui_print "*******************************"
  ui_print " Please install Magisk v20.4+! "
  ui_print "*******************************"
  exit 1
}

#########################
# Load util_functions.sh
#########################

SKIPUNZIP=1
OUTFD=$2
ZIPFILE=$3

# Mount required partitions
mount /data 2>/dev/null

# Try to load Magisk util_functions
if [ -f /data/adb/magisk/util_functions.sh ]; then
  . /data/adb/magisk/util_functions.sh
elif [ -f /data/adb/ksu/util_functions.sh ]; then
  . /data/adb/ksu/util_functions.sh
elif [ -f /data/adb/ap/util_functions.sh ]; then
  . /data/adb/ap/util_functions.sh
else
  require_new_magisk
fi

[ "$MAGISK_VER_CODE" ] || require_new_magisk
[ "$MAGISK_VER_CODE" -lt 20400 ] && require_new_magisk

##########################
# Prepare module directory
##########################

setup_flashable
mount_partitions
api_level_arch_detect
setup_modules
MODPATH=$TMPDIR/module

##############
# Main
##############

print_modname() {
  ui_print "  SSHCustom-VPNChain"
}

# Extract customize.sh and run it
unzip -o "$ZIPFILE" customize.sh -d "$MODPATH" >/dev/null 2>&1
. "$MODPATH/customize.sh"

# Copy module to final location
copy_dir "$MODPATH" "$NVBASE/modules_update/$MODID"

# Cleanup
rm -rf "$TMPDIR"
