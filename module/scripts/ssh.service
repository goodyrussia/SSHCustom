#!/system/bin/sh
WORK_DIR="/data/adb/sshcustom"
DAEMON="$WORK_DIR/bin/sshcustomd"
SETTINGS="$WORK_DIR/settings.ini"
case "$1" in
    start) $DAEMON run -c "$SETTINGS" -w "$WORK_DIR" & echo $! > "$WORK_DIR/run/pid" ;;
    stop) kill $(cat "$WORK_DIR/run/pid" 2>/dev/null) 2>/dev/null || true ;;
    restart) $0 stop; sleep 1; $0 start ;;
    status) if [ -f "$WORK_DIR/run/pid" ] && kill -0 $(cat "$WORK_DIR/run/pid") 2>/dev/null; then echo "running"; else echo "stopped"; fi ;;
esac
