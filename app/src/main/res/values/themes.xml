<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        SSHCustom theme — window chrome only.
        miuix handles all UI theming via MiuixTheme composable.
        We use Theme.Material.NoTitleBar to avoid AppCompat dependency
        while still getting edge-to-edge window setup.
    -->
    <style name="Theme.SSHCustom" parent="android:Theme.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
